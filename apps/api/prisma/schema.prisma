generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  companies   Company[]
  persons     Person[]
  employees   Employee[]
  admissions  AdmissionRequest[]
  admissionChecklistItems AdmissionChecklistItem[]
  admissionHistories AdmissionHistory[]
  admissionContracts AdmissionContract[]
  admissionDocuments AdmissionDocument[]
  admissionEsocialTransmissions AdmissionEsocialTransmission[]
  recruitmentVacancyRequests RecruitmentVacancyRequest[]
  recruitmentCandidates RecruitmentCandidate[]
  recruitmentInterviews RecruitmentInterview[]
  recruitmentCandidateEvaluations RecruitmentCandidateEvaluation[]
  recruitmentProposals RecruitmentProposal[]
  terminationRequests TerminationRequest[]
  terminationHistories TerminationHistory[]
  terminationOffboardings TerminationOffboarding[]
  terminationOffboardingHistories TerminationOffboardingHistory[]
  terminationEsocialTransmissions TerminationEsocialTransmission[]
  benefitCatalogs BenefitCatalog[]
  employeeBenefits EmployeeBenefit[]
  privacyConsents PrivacyConsent[]
  dataSubjectRequests DataSubjectRequest[]
  vacationBalances VacationBalance[]
  vacationRequests VacationRequest[]
  vacationRequestPeriods VacationRequestPeriod[]
  vacationEsocialTransmissions VacationEsocialTransmission[]
  rescissionRequests RescissionRequest[]
  rescissionHistories RescissionHistory[]
  rescissionCalculations RescissionCalculation[]
  rescissionDocuments RescissionDocument[]
  nightShiftAllowanceCalculations NightShiftAllowanceCalculation[]
  nightShiftAllowanceItems NightShiftAllowanceItem[]
  weeklyRestAllowanceCalculations WeeklyRestAllowanceCalculation[]
  weeklyRestAllowanceItems WeeklyRestAllowanceItem[]
  thirteenthSalaryCalculations ThirteenthSalaryCalculation[]
  timeSheetPayrollEventBatches TimeSheetPayrollEventBatch[]
  timeSheetPayrollEventBatchItems TimeSheetPayrollEventBatchItem[]
  integrationRequests ApiIntegrationRequest[]
  integrationRequestHistories ApiIntegrationRequestHistory[]
  occupationalHealthEnvironments OccupationalHealthEnvironment[]
  occupationalHealthPgrs OccupationalHealthPgr[]
  occupationalHealthPcmsos OccupationalHealthPcmso[]
  occupationalHealthRisks OccupationalHealthRisk[]
  occupationalHealthCats OccupationalHealthCat[]
  occupationalHealthEpiCatalogs OccupationalHealthEpiCatalog[]
  occupationalHealthEpiAssignments OccupationalHealthEpiAssignment[]
  occupationalHealthExams OccupationalHealthExam[]
  occupationalHealthAsos OccupationalHealthAso[]
  occupationalHealthEsocialTransmissions OccupationalHealthEsocialTransmission[]
  occupationalHealthTrainingCatalogs OccupationalHealthTrainingCatalog[]
  occupationalHealthTrainingAssignments OccupationalHealthTrainingAssignment[]
  pointMarks  PointMark[]
  pointHolidayCalendars PointHolidayCalendar[]
  pointToleranceRules PointToleranceRule[]
  pointDevices PointDevice[]
  employeeDependents EmployeeDependent[]
  auditEvents AuditEvent[]
  accessGrants TenantAccess[]

  @@map("tenants")
}

model TenantAccess {
  id         String   @id @default(uuid())
  tenantId   String
  subject    String
  role       String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, subject])
  @@index([subject])
  @@map("tenant_access")
}

model Company {
  id         String   @id @default(uuid())
  tenantId   String
  legalName  String
  tradeName  String?
  cnpj       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees  Employee[]
  admissions AdmissionRequest[]
  recruitmentVacancyRequests RecruitmentVacancyRequest[]
  recruitmentCandidates RecruitmentCandidate[]
  recruitmentInterviews RecruitmentInterview[]
  recruitmentCandidateEvaluations RecruitmentCandidateEvaluation[]
  recruitmentProposals RecruitmentProposal[]
  pointHolidayCalendars PointHolidayCalendar[]
  pointToleranceRules PointToleranceRule[]
  pointDevices PointDevice[]
  occupationalHealthEnvironments OccupationalHealthEnvironment[]
  occupationalHealthPgrs OccupationalHealthPgr[]
  occupationalHealthPcmsoPrograms OccupationalHealthPcmso[]
  occupationalHealthCats OccupationalHealthCat[]
  occupationalHealthEpiCatalogs OccupationalHealthEpiCatalog[]
  occupationalHealthEpiAssignments OccupationalHealthEpiAssignment[]
  occupationalHealthTrainingCatalogs OccupationalHealthTrainingCatalog[]
  occupationalHealthTrainingAssignments OccupationalHealthTrainingAssignment[]

  @@unique([tenantId, cnpj])
  @@map("companies")
}

model Person {
  id         String   @id @default(uuid())
  tenantId   String
  fullName   String
  cpf        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees  Employee[]
  admissions AdmissionRequest[]

  @@unique([tenantId, cpf])
  @@map("persons")
}

model Employee {
  id         String   @id @default(uuid())
  tenantId   String
  companyId  String
  personId   String
  code       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  admissions AdmissionRequest[]
  terminations TerminationRequest[]
  offboardings TerminationOffboarding[]
  rescissions RescissionRequest[]
  employeeBenefits EmployeeBenefit[]
  vacationBalances VacationBalance[]
  vacationRequests VacationRequest[]
  nightShiftAllowanceCalculations NightShiftAllowanceCalculation[]
  weeklyRestAllowanceCalculations WeeklyRestAllowanceCalculation[]
  thirteenthSalaryCalculations ThirteenthSalaryCalculation[]
  occupationalHealthCats OccupationalHealthCat[]
  occupationalHealthEpiAssignments OccupationalHealthEpiAssignment[]
  occupationalHealthTrainingAssignments OccupationalHealthTrainingAssignment[]
  timeSheetPayrollEventBatches TimeSheetPayrollEventBatch[]
  occupationalHealthExams OccupationalHealthExam[]
  occupationalHealthAsos OccupationalHealthAso[]
  pointMarks PointMark[]

  dependents EmployeeDependent[]

  @@unique([tenantId, code])
  @@map("employees")
}

model EmployeeDependent {
  id               String   @id @default(uuid())
  tenantId         String
  employeeId       String
  fullName         String
  cpf              String?
  birthDate        DateTime
  relationshipType String
  status           String   @default("active")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, cpf])
  @@unique([tenantId, employeeId, fullName, birthDate, relationshipType])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("employee_dependents")
}

model PrivacyConsent {
  id           String   @id @default(uuid())
  tenantId     String
  subjectType  String
  subjectId    String
  purpose      String
  scope        String?
  status       String   @default("accepted")
  grantedAt    DateTime  @default(now())
  revokedAt    DateTime?
  expiresAt    DateTime?
  notes        String?
  recordedBy   String?
  revokedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectType, subjectId])
  @@index([tenantId, status])
  @@map("privacy_consents")
}

model DataSubjectRequest {
  id              String   @id @default(uuid())
  tenantId        String
  subjectType     String
  subjectId       String
  requestType     String
  status          String   @default("open")
  requestedAt     DateTime @default(now())
  resolvedAt      DateTime?
  responseSummary String?
  notes           String?
  requestedBy     String?
  resolvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectType, subjectId])
  @@index([tenantId, status])
  @@map("data_subject_requests")
}

model BenefitCatalog {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  benefitType String
  description String?
  active      Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments EmployeeBenefit[]

  @@unique([tenantId, code])
  @@index([tenantId, benefitType])
  @@map("benefit_catalogs")
}

model EmployeeBenefit {
  id              String   @id @default(uuid())
  tenantId        String
  employeeId      String
  benefitCatalogId String
  status          String   @default("active")
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  notes           String?
  requestedBy     String?
  requestedAt     DateTime @default(now())
  changedBy       String?
  changedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  benefitCatalog  BenefitCatalog @relation(fields: [benefitCatalogId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, benefitCatalogId])
  @@index([tenantId, status])
  @@map("employee_benefits")
}

model VacationBalance {
  id              String   @id @default(uuid())
  tenantId        String
  employeeId      String
  referenceStart   DateTime
  referenceEnd     DateTime
  accruedDays      Int      @default(30)
  takenDays        Int      @default(0)
  availableDays    Int      @default(30)
  status          String   @default("open")
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requests        VacationRequest[]

  @@unique([tenantId, employeeId, referenceStart, referenceEnd])
  @@index([tenantId, status])
  @@map("vacation_balances")
}

model VacationRequest {
  id              String   @id @default(uuid())
  tenantId        String
  employeeId      String
  vacationBalanceId String
  plannedStart    DateTime
  plannedEnd      DateTime
  requestedDays   Int
  consumedDays    Int      @default(0)
  abonoDays       Int      @default(0)
  salaryBaseCents Int?
  vacationAmountCents Int  @default(0)
  abonoAmountCents Int     @default(0)
  status          String   @default("requested")
  notes           String?
  requestedBy     String?
  requestedAt     DateTime @default(now())
  decidedBy       String?
  decidedAt       DateTime?
  noticeIssuedAt  DateTime?
  noticeProtocol  String?
  paymentDueAt    DateTime?
  paidAt          DateTime?
  paidBy          String?
  payrollBatchId  String?
  payrollStatus   String?
  payrollReceiptNumber String?
  payrollSentBy   String?
  payrollSentAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  balance         VacationBalance @relation(fields: [vacationBalanceId], references: [id], onDelete: Cascade)
  payrollBatch    TimeSheetPayrollEventBatch? @relation(fields: [payrollBatchId], references: [id], onDelete: SetNull)
  periods         VacationRequestPeriod[]
  esocialTransmissions VacationEsocialTransmission[]

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("vacation_requests")
}

model VacationRequestPeriod {
  id                String   @id @default(uuid())
  tenantId          String
  vacationRequestId String
  sequence          Int
  plannedStart      DateTime
  plannedEnd        DateTime
  requestedDays     Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request           VacationRequest @relation(fields: [vacationRequestId], references: [id], onDelete: Cascade)

  @@unique([vacationRequestId, sequence])
  @@index([tenantId, vacationRequestId])
  @@map("vacation_request_periods")
}

model AdmissionRequest {
  id          String               @id @default(uuid())
  tenantId    String
  sourceCandidateId String?
  sourceProposalId   String?
  personId    String
  companyId   String
  employeeId  String
  status      String
  requestedBy String?
  requestedAt DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person      Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  checklistItems AdmissionChecklistItem[]
  history     AdmissionHistory[]
  contract    AdmissionContract?
  documents   AdmissionDocument[]
  esocialTransmissions AdmissionEsocialTransmission[]

  @@index([tenantId, status])
  @@index([tenantId, employeeId])
  @@index([tenantId, sourceCandidateId])
  @@index([tenantId, sourceProposalId])
  @@map("admission_requests")
}

model AdmissionChecklistItem {
  id               String           @id @default(uuid())
  tenantId         String
  admissionRequestId String
  code             String
  label            String
  required         Boolean          @default(true)
  status           String           @default("pending")
  receivedBy       String?
  receivedAt       DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admissionRequest AdmissionRequest  @relation(fields: [admissionRequestId], references: [id], onDelete: Cascade)

  @@unique([admissionRequestId, code])
  @@index([tenantId, admissionRequestId])
  @@map("admission_checklist_items")
}

model AdmissionHistory {
  id               String           @id @default(uuid())
  tenantId         String
  admissionRequestId String
  eventType        String
  fromStatus       String?
  toStatus         String?
  actor            String?
  occurredAt       DateTime         @default(now())
  details          Json
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admissionRequest AdmissionRequest  @relation(fields: [admissionRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId, admissionRequestId])
  @@map("admission_history")
}

model AdmissionContract {
  id                String   @id @default(uuid())
  tenantId          String
  admissionRequestId String   @unique
  contractType      String
  effectiveFrom     DateTime
  status            String   @default("formalized")
  notes             String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admissionRequest  AdmissionRequest @relation(fields: [admissionRequestId], references: [id], onDelete: Cascade)
  documents        AdmissionDocument[]
  esocialTransmissions AdmissionEsocialTransmission[]

  @@index([tenantId, admissionRequestId])
  @@map("admission_contracts")
}

model AdmissionDocument {
  id                 String   @id @default(uuid())
  tenantId           String
  admissionRequestId  String
  admissionContractId String?
  documentType       String
  title              String
  status             String   @default("generated")
  signedBy           String?
  signedAt           DateTime?
  signatureMethod    String?
  content            Json
  generatedBy        String?
  generatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admissionRequest   AdmissionRequest @relation(fields: [admissionRequestId], references: [id], onDelete: Cascade)
  admissionContract  AdmissionContract? @relation(fields: [admissionContractId], references: [id], onDelete: SetNull)

  @@unique([admissionRequestId, documentType])
  @@index([tenantId, admissionRequestId])
  @@index([tenantId, documentType])
  @@map("admission_documents")
}

model AdmissionEsocialTransmission {
  id                 String   @id @default(uuid())
  tenantId           String
  admissionRequestId String
  admissionContractId String?
  eventCode          String
  status             String   @default("queued")
  payload            Json
  receiptNumber      String?
  response           Json?
  errorMessage       String?
  queuedAt           DateTime @default(now())
  sentAt             DateTime?
  processedAt        DateTime?
  attempts           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admissionRequest   AdmissionRequest @relation(fields: [admissionRequestId], references: [id], onDelete: Cascade)
  admissionContract  AdmissionContract? @relation(fields: [admissionContractId], references: [id], onDelete: Cascade)

  @@unique([admissionRequestId, eventCode])
  @@index([tenantId, admissionRequestId])
  @@index([tenantId, status])
  @@map("admission_esocial_transmissions")
}

model TerminationRequest {
  id             String   @id @default(uuid())
  tenantId       String
  employeeId     String
  status         String   @default("draft")
  reason         String
  effectiveAt    DateTime
  noticeType     String?
  requestedBy    String?
  requestedAt    DateTime @default(now())
  approvedBy     String?
  approvedAt     DateTime?
  effectiveBy    String?
  effectiveOn    DateTime?
  cancelledBy    String?
  cancelledAt    DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  histories      TerminationHistory[]
  offboarding    TerminationOffboarding?
  esocialTransmissions TerminationEsocialTransmission[]
  rescissions    RescissionRequest[]

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("termination_requests")
}

model TerminationOffboarding {
  id                  String   @id @default(uuid())
  tenantId            String
  terminationRequestId String   @unique
  employeeId          String
  status              String   @default("draft")
  requestedBy         String?
  requestedAt         DateTime @default(now())
  closedBy            String?
  closedAt            DateTime?
  cancelledBy         String?
  cancelledAt         DateTime?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminationRequest  TerminationRequest @relation(fields: [terminationRequestId], references: [id], onDelete: Cascade)
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  histories           TerminationOffboardingHistory[]
  esocialTransmissions TerminationEsocialTransmission[]

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("termination_offboardings")
}

model TerminationOffboardingHistory {
  id                    String   @id @default(uuid())
  tenantId              String
  terminationOffboardingId String
  eventType             String
  fromStatus            String?
  toStatus              String?
  actor                 String?
  occurredAt            DateTime @default(now())
  details               Json
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminationOffboarding TerminationOffboarding @relation(fields: [terminationOffboardingId], references: [id], onDelete: Cascade)

  @@index([tenantId, terminationOffboardingId])
  @@map("termination_offboarding_history")
}

model TerminationEsocialTransmission {
  id                    String   @id @default(uuid())
  tenantId              String
  terminationRequestId  String
  terminationOffboardingId String
  eventCode             String
  status                String   @default("queued")
  payload               Json
  receiptNumber         String?
  response              Json?
  errorMessage          String?
  queuedAt              DateTime @default(now())
  sentAt                DateTime?
  processedAt           DateTime?
  attempts              Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminationRequest    TerminationRequest @relation(fields: [terminationRequestId], references: [id], onDelete: Cascade)
  terminationOffboarding TerminationOffboarding @relation(fields: [terminationOffboardingId], references: [id], onDelete: Cascade)

  @@unique([terminationRequestId, eventCode])
  @@index([tenantId, terminationRequestId])
  @@index([tenantId, status])
  @@map("termination_esocial_transmissions")
}

model TerminationHistory {
  id               String   @id @default(uuid())
  tenantId         String
  terminationRequestId String
  eventType        String
  fromStatus       String?
  toStatus         String?
  actor            String?
  occurredAt       DateTime @default(now())
  details          Json
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminationRequest TerminationRequest @relation(fields: [terminationRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId, terminationRequestId])
  @@map("termination_history")
}

model RescissionRequest {
  id                  String   @id @default(uuid())
  tenantId            String
  terminationRequestId String
  employeeId          String
  status              String   @default("draft")
  paymentDueAt        DateTime?
  requestedBy        String?
  requestedAt        DateTime @default(now())
  closedBy           String?
  closedAt           DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminationRequest TerminationRequest @relation(fields: [terminationRequestId], references: [id], onDelete: Cascade)
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  histories          RescissionHistory[]
  calculation        RescissionCalculation?
  documents          RescissionDocument[]

  @@unique([terminationRequestId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("rescission_requests")
}

model RescissionCalculation {
  id                       String   @id @default(uuid())
  tenantId                 String
  rescissionRequestId      String   @unique
  status                   String   @default("calculated")
  referenceSalaryCents     Int?
  noticeAmountCents        Int      @default(0)
  salaryBalanceAmountCents Int      @default(0)
  vacationAmountCents      Int      @default(0)
  thirteenthAmountCents    Int      @default(0)
  fgtsAmountCents          Int      @default(0)
  fgtsPenaltyAmountCents   Int      @default(0)
  deductionsAmountCents    Int      @default(0)
  grossAmountCents         Int
  netAmountCents           Int
  notes                    String?
  calculatedBy             String?
  calculatedAt             DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rescissionRequest        RescissionRequest @relation(fields: [rescissionRequestId], references: [id], onDelete: Cascade)
  documents                RescissionDocument[]

  @@index([tenantId, rescissionRequestId])
  @@map("rescission_calculations")
}

model RescissionDocument {
  id                 String   @id @default(uuid())
  tenantId           String
  rescissionRequestId String
  calculationId      String?
  documentType       String
  title              String
  status             String   @default("generated")
  signedBy           String?
  signedAt           DateTime?
  signatureMethod    String?
  content            Json
  generatedBy        String?
  generatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rescissionRequest  RescissionRequest @relation(fields: [rescissionRequestId], references: [id], onDelete: Cascade)
  calculation        RescissionCalculation? @relation(fields: [calculationId], references: [id], onDelete: SetNull)

  @@unique([rescissionRequestId, documentType])
  @@index([tenantId, rescissionRequestId])
  @@index([tenantId, documentType])
  @@map("rescission_documents")
}

model RescissionHistory {
  id               String   @id @default(uuid())
  tenantId         String
  rescissionRequestId String
  eventType        String
  fromStatus       String?
  toStatus         String?
  actor            String?
  occurredAt       DateTime @default(now())
  details          Json
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rescissionRequest RescissionRequest @relation(fields: [rescissionRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId, rescissionRequestId])
  @@map("rescission_history")
}

model PointMark {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  occurredAt DateTime
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("point_marks")
}

model NightShiftAllowanceCalculation {
  id               String   @id @default(uuid())
  tenantId         String
  employeeId       String
