{
  "realm": "rh",
  "enabled": true,
  "displayName": "RH",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "roles": {
    "realm": [
      { "name": "admin" },
      { "name": "rh" },
      { "name": "manager" },
      { "name": "employee" },
      { "name": "auditor" }
    ]
  },
  "clients": [
    {
      "clientId": "rh-web",
      "name": "RH Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://172.17.0.3:5173/*",
        "https://172.17.0.3:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://172.17.0.3:5173",
        "https://172.17.0.3:5173"
      ],
      "protocolMappers": [
        {
          "name": "realm roles to rh_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "rh_roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "rh-cli",
      "name": "RH CLI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocolMappers": [
        {
          "name": "realm roles to rh_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "rh_roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@rh.local",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "RH",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "rh-user",
      "enabled": true,
      "email": "rh@rh.local",
      "emailVerified": true,
      "firstName": "RH",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "rh123",
          "temporary": false
        }
      ],
      "realmRoles": ["rh"]
    }
  ]
}
